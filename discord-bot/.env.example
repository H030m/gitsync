# GitSync forwarder bot config. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real tokens/secrets.

# 1. Discord bot token (Discord Developer Portal → your app → Bot → Reset Token).
#    The bot must have the "Message Content Intent" enabled in the portal.
DISCORD_BOT_TOKEN=REPLACE_ME

# 2. Shared secret sent as the `x-ingest-secret` header. MUST match the
#    DISCORD_INGEST_SECRET configured for the discordMessageIngest Cloud Function
#    (functions/.secret.local for the emulator, or Secret Manager in prod).
DISCORD_INGEST_SECRET=REPLACE_ME

# 3. URL of the discordMessageIngest Cloud Function.
#    Emulator: http://127.0.0.1:5001/<firebase-project-id>/asia-east1/discordMessageIngest
#    Prod:     https://asia-east1-<firebase-project-id>.cloudfunctions.net/discordMessageIngest
INGEST_URL=http://127.0.0.1:5001/gitsync-645b3/asia-east1/discordMessageIngest

# 4. Which channels to forward, mapped to a repoId. Comma-separated `channelId:repoId`
#    pairs. Messages from channels NOT listed here are ignored.
CHANNEL_REPO_MAP=123456789012345678:team17_gitsync
